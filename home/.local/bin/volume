#!/bin/sh
# Volume helper with a minimal on-screen notification.
#   volume up      raise the default sink by one step
#   volume down    lower the default sink by one step
#   volume mute    toggle mute on the default sink
#
# Adjusts the level with pactl, then shows a dunst notification carrying a
# progress bar (int:value) and nothing else. Reusing one stack tag means
# repeated key presses replace the popup instead of piling up.

STEP=5      # percentage points per press
MAX=100     # ceiling; raising past this is clamped so the bar stays sane

# Resolve the real sink name. The @DEFAULT_SINK@ alias is only understood by
# pactl's set-* commands, not get-sink-volume/get-sink-mute, so reading it back
# would yield nothing and break the clamp on the way up.
SINK=$(pactl get-default-sink)

# First percentage in `pactl get-sink-volume` output. A stereo sink prints both
# channels on one line, so `-o` would emit two numbers; head pins it to one.
get_volume() {
	pactl get-sink-volume "$SINK" | grep -oP '\d+(?=%)' | head -n1
}

notify() {
	# string:x-dunst-stack-tag:volume -> collapse onto a single popup.
	dunstify -a volume -u low -t 1500 \
		-h string:x-dunst-stack-tag:volume \
		-h "int:value:$1" \
		"$2"
}

case "$1" in
up)
	# Raise relatively (same mechanism as "down", which is known to work),
	# then pin back down if we overshot MAX. The clamp is best-effort: if the
	# level can't be read it is simply skipped rather than blocking the raise.
	pactl set-sink-volume "$SINK" "+${STEP}%"
	cur=$(get_volume)
	case "$cur" in
	''|*[!0-9]*) ;;
	*) [ "$cur" -gt "$MAX" ] && pactl set-sink-volume "$SINK" "${MAX}%" ;;
	esac
	pactl set-sink-mute "$SINK" 0
	;;
down)
	pactl set-sink-volume "$SINK" "-${STEP}%"
	pactl set-sink-mute "$SINK" 0
	;;
mute)
	pactl set-sink-mute "$SINK" toggle
	;;
*)
	echo "usage: ${0##*/} {up|down|mute}" >&2
	exit 1
	;;
esac

if pactl get-sink-mute "$SINK" | grep -q yes; then
	notify 0 "Muted"
else
	vol=$(get_volume)
	case "$vol" in ''|*[!0-9]*) vol=0 ;; esac
	notify "$vol" "Volume ${vol}%"
fi
