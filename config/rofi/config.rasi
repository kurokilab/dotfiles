/* rofi configuration — behaviour lives here, looks live in gruvbox-dark.rasi */
configuration {
    modi:                "drun";
    show-icons:          true;
    icon-theme:          "Adwaita";
    drun-display-format: "{name}";
    terminal:            "alacritty";
    kb-cancel:           "Escape,Super+d";
}

@theme "gruvbox-dark"
