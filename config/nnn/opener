#!/usr/bin/env bash
# Custom nnn opener.  nnn invokes:  opener <filepath>
# Wired up via $NNN_OPENER (set in ~/.zshrc).
#
# Routing:
#   - GUI programs are spawned fully detached, so neither nnn nor the
#     terminal ever block while the app is open.
#   - Terminal programs (editor, pager) run in the foreground and take over
#     the tty until you quit them.
#   - We route by MIME type first, then fall back to the file extension for
#     the handful of cases `file` guesses wrong (mostly source files).
#   - Anything we don't recognise is handed to xdg-open as a last resort.

set -u

f="${1:-}"
[ -n "$f" ] || exit 0          # nnn called us with nothing
[ -e "$f" ] || exit 1          # vanished / broken path

# ---------------------------------------------------------------------------
#  helpers
# ---------------------------------------------------------------------------

# pick <cmd>...  -> prints the first command found on $PATH (exit 1 if none)
pick() {
    local c
    for c in "$@"; do
        command -v -- "$c" >/dev/null 2>&1 && { printf '%s\n' "$c"; return 0; }
    done
    return 1
}

# spawn <cmd> [args...]  -> launch a GUI app detached from this terminal
spawn() {
    if command -v setsid >/dev/null 2>&1; then
        setsid -f "$@" >/dev/null 2>&1
    else
        ( "$@" >/dev/null 2>&1 & ) &
    fi
}

# open_gui <file> [candidate-app...]
#   Open <file> with the first available candidate; if none are installed
#   (or none were given) fall back to xdg-open, then give up loudly.
open_gui() {
    local file="$1"; shift
    local app
    if app="$(pick "$@")"; then
        spawn "$app" -- "$file"
    elif command -v xdg-open >/dev/null 2>&1; then
        spawn xdg-open "$file"          # xdg-open takes no `--`
    else
        printf 'opener: no GUI handler for %s\n' "$file" >&2
        return 1
    fi
}

# edit <file>  -> open in the terminal editor, in the foreground
edit() { "${EDITOR:-nvim}" -- "$1"; }

# list_archive <file>  -> show contents in a pager (never extract blindly)
list_archive() {
    local file="$1" lister
    if lister="$(pick bsdtar atool 7z)"; then
        case "$lister" in
            bsdtar) bsdtar -tvf "$file" ;;
            atool)  atool -l -- "$file" ;;
            7z)     7z l -- "$file" ;;
        esac 2>&1 | "${PAGER:-less}"
    else
        open_gui "$file"                # let a desktop archive manager handle it
    fi
}

# ---------------------------------------------------------------------------
#  classify
# ---------------------------------------------------------------------------

mime="$(file -bL --mime-type -- "$f" 2>/dev/null || true)"

# lowercase extension of the basename (empty if the name has no dot)
base="${f##*/}"
ext=""
case "$base" in *.*) ext="${base##*.}"; ext="${ext,,}" ;; esac

case "$mime" in
    text/* | \
    application/json | application/javascript | application/xml | \
    application/x-shellscript | application/x-yaml | application/toml | \
    inode/x-empty)
        edit "$f" ;;

    image/*)
        open_gui "$f" feh imv sxiv nsxiv ;;

    audio/* | video/*)
        open_gui "$f" mpv vlc ;;

    application/pdf)
        open_gui "$f" mupdf chromium ;;

    application/zip | application/x-tar | application/gzip | \
    application/x-bzip2 | application/x-xz | application/zstd | \
    application/x-7z-compressed | application/vnd.rar | application/x-rar)
        list_archive "$f" ;;

    *)
        # MIME was unhelpful (often application/octet-stream); use extension.
        case "$ext" in
            md|txt|text|log|conf|config|ini|toml|yaml|yml|cfg|rc|env|desktop| \
            c|h|cpp|hpp|cc|cxx|sh|bash|zsh|py|go|lua|rs|rb|pl|java|kt| \
            js|ts|jsx|tsx|json|xml|css|scss|sql|vim|nvim)
                edit "$f" ;;
            htm|html|xhtml)
                open_gui "$f" chromium firefox ;;
            epub|mobi)
                open_gui "$f" mupdf ;;
            *)
                open_gui "$f" ;;        # → xdg-open
        esac ;;
esac
